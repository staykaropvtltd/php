{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.2"
    },
    "*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    { "src": "/api/(.*)\\.php", "dest": "/api/$1.php" },
    { "src": "/(.*)\\.php", "dest": "/$1.php" },
    { "src": "/", "dest": "/index.php" }
  ]
}
